---
import Base from '../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const PLACEHOLDER = '/images/people/placeholder.svg';

const people = await getCollection('people');
const byOrder = (a: (typeof people)[number], b: (typeof people)[number]) =>
  a.data.order - b.data.order || a.data.name.localeCompare(b.data.name);

const pi = people.find((p) => p.data.role === 'Principal Investigator');
const PiContent = pi ? (await render(pi)).Content : null;

// All students share one "Current Students" section; postdocs and visitors
// get their own sections when the lab has them.
const sections = [
  { label: 'Postdoctoral Researchers', roles: ['Postdoctoral Researcher'] },
  { label: 'Current Students', roles: ['PhD Student', 'MSc Student', 'Undergraduate Student'] },
  { label: 'Visiting Researchers', roles: ['Visiting Researcher'] },
];

// Render each member's markdown body (topics + "From:" line)
const grouped = [];
for (const { label, roles } of sections) {
  const members = people.filter((p) => roles.includes(p.data.role)).sort(byOrder);
  if (members.length === 0) continue;
  grouped.push({
    label,
    members: await Promise.all(
      members.map(async (p) => ({ p, Content: (await render(p)).Content }))
    ),
  });
}

// Summer students appear under Current Students too, but as compact
// text-only rows (no photo).
const summer = await Promise.all(
  people
    .filter((p) => p.data.role === 'Summer Student')
    .sort(byOrder)
    .map(async (p) => ({ p, Content: (await render(p)).Content }))
);

// Make sure the Current Students section exists even if only summer
// students are present.
if (summer.length > 0 && !grouped.some((g) => g.label === 'Current Students')) {
  grouped.push({ label: 'Current Students', members: [] });
}

const alumni = people.filter((p) => p.data.role === 'Alumni').sort(byOrder);
---

<Base title="Team">
  <section class="section">
    <div class="container">
      <h2 class="section-title">Team</h2>

      {pi && <h3 class="year-heading">Principal Investigator</h3>}
      {pi && (
        <div class="pi-card">
          <img src={pi.data.photo ?? PLACEHOLDER} alt={pi.data.name} />
          <div>
            <h3>{pi.data.name}</h3>
            <p class="member-meta">
              Principal Investigator · Assistant Professor<br />
              {pi.data.email && <a href={`mailto:${pi.data.email}`}>{pi.data.email}</a>}
            </p>
            {PiContent && (
              <div class="member-body">
                <PiContent />
              </div>
            )}
            <p class="person-links">
              {pi.data.website && <a href={pi.data.website} rel="noopener">UCalgary Profile</a>}
              {pi.data.scholar && <a href={pi.data.scholar} rel="noopener">Google Scholar</a>}
            </p>
          </div>
        </div>
      )}

      {grouped.map(({ label, members }) => (
        <>
          <h3 class="year-heading">{label}</h3>
          <div class="member-list">
            {members.map(({ p, Content }) => (
              <div class="member-row">
                <img src={p.data.photo ?? PLACEHOLDER} alt={p.data.name} loading="lazy" />
                <div>
                  <h3>
                    {p.data.website ? (
                      <a href={p.data.website} rel="noopener">{p.data.name}</a>
                    ) : p.data.scholar ? (
                      <a href={p.data.scholar} rel="noopener">{p.data.name}</a>
                    ) : (
                      p.data.name
                    )}
                  </h3>
                  <p class="member-meta">
                    {p.data.role}
                    {p.data.email && (
                      <>
                        <br />
                        <a href={`mailto:${p.data.email}`}>{p.data.email}</a>
                      </>
                    )}
                  </p>
                  <div class="member-body">
                    <Content />
                  </div>
                </div>
              </div>
            ))}
            {label === 'Current Students' &&
              summer.map(({ p, Content }) => (
                <div class="member-row member-row--compact">
                  <div>
                    <h3>{p.data.name}</h3>
                    <p class="member-meta">
                      Summer Student
                      {p.data.email && (
                        <>
                          <br />
                          <a href={`mailto:${p.data.email}`}>{p.data.email}</a>
                        </>
                      )}
                    </p>
                    <div class="member-body">
                      <Content />
                    </div>
                  </div>
                </div>
              ))}
          </div>
        </>
      ))}

      {alumni.length > 0 && (
        <>
          <h3 class="year-heading">Alumni</h3>
          <ul class="alumni-list">
            {alumni.map((p) => (
              <li>
                <strong>{p.data.name}</strong>
                {p.data.note && <span class="person-meta"> — {p.data.note}</span>}
              </li>
            ))}
          </ul>
        </>
      )}
    </div>
  </section>
</Base>
